ELEVENLABS_API_KEY=
RESEND_API_KEY=
DJANGO_SECRET_KEY=

# ------------------------------------------------------------
# Environment & monitoring
# DJANGO_ENV: 'development' or 'production' (shown in Sentry events)
# SENTRY_DSN: get from https://sentry.io (free tier) or leave empty to disable
# ------------------------------------------------------------
DJANGO_ENV=development
SENTRY_DSN=

# ------------------------------------------------------------
# Cloudflare Stream
# ------------------------------------------------------------
CLOUDFLARE_ACCOUNT_ID=a74db7fd24fd9c88bd063e7b7ea3cda7
CLOUDFLARE_STREAM_TOKEN=MKAIkgxfFKemnLqZMDZCtJ5vezLDxLlzVv3b92M3
CLOUDFLARE_STREAM_ENABLED=true

# ------------------------------------------------------------
# Cloudflare R2 — S3-compatible storage
# Get these from: Cloudflare Dashboard → R2 → Manage R2 API tokens
# ------------------------------------------------------------
CLOUDFLARE_R2_ACCOUNT_ID=a74db7fd24fd9c88bd063e7b7ea3cda7
CLOUDFLARE_R2_BUCKET_NAME=withthanks
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=

# ------------------------------------------------------------
# Blackbaud SKY API — shared application credentials
# Register your app at: https://developer.sky.blackbaud.com
# Each charity connects their own RE NXT account via OAuth;
# these credentials identify WithThanks as the OAuth client.
# ------------------------------------------------------------
BLACKBAUD_CLIENT_ID=
BLACKBAUD_CLIENT_SECRET=
# Ocp-Apim-Subscription-Key from your Blackbaud developer portal application
BLACKBAUD_SUBSCRIPTION_KEY=
# Must exactly match the redirect URI registered in your Blackbaud app
BLACKBAUD_REDIRECT_URI=https://yourdomain.com/charity/crm/blackbaud/callback/
