# -------------------------------------------------------
# WithThanks – Environment Variables
# Copy this file to .env and fill in real values.
# Never commit .env to version control.
# -------------------------------------------------------

# ── Django ──────────────────────────────────────────────
# Production: REQUIRED. Local management commands have a development fallback,
# but setting this explicitly is still recommended.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(50))"
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
# Set to production for portal.with-thanks.co.uk.
# Set to development for dev.with-thanks.co.uk.
DJANGO_ENV=development
# Optional startup bootstrap for admin access.
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@example.com
# Set this only if you want the container to create/update the admin user on boot.
DJANGO_SUPERUSER_PASSWORD=
# Local default in docs is true.
DJANGO_DEBUG=true

# Comma-separated list of hostnames the app is served from.
# Example: myapp.example.com,www.myapp.example.com
# Hosted dev example: dev.with-thanks.co.uk
# Production example: portal.with-thanks.co.uk
# Production: REQUIRED. Do not include localhost entries.
ALLOWED_HOSTS=localhost,127.0.0.1

# Comma-separated CSRF trusted origins (include scheme).
# Example: https://myapp.example.com
# Hosted dev example: https://dev.with-thanks.co.uk
# Production example: https://portal.with-thanks.co.uk
# Production: REQUIRED and must use https origins.
CSRF_TRUSTED_ORIGINS=http://localhost:8000

# ── Database ─────────────────────────────────────────────
# Leave empty to use SQLite (development only).
# Production: postgresql://user:password@host:5432/dbname
DATABASE_URL=

# ── Media / storage ──────────────────────────────────────
MEDIA_ROOT=/app/media

# ── Cloudflare Stream ────────────────────────────────────
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_STREAM_TOKEN=
# Set to "false" to disable Stream and fall back to email attachments.
CLOUDFLARE_STREAM_ENABLED=true

# ── Cloudflare R2 (optional) ─────────────────────────────
# Set all four values to enable R2.
# Leave them all empty to use local filesystem storage in development.
CLOUDFLARE_R2_ACCOUNT_ID=
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_BUCKET_NAME=

# ── ElevenLabs ───────────────────────────────────────────
ELEVENLABS_API_KEY=
# Default voice ID used when a campaign has no voice_id set.
ELEVENLABS_DEFAULT_VOICE_ID=

# ── Resend (email delivery) ───────────────────────────────
RESEND_API_KEY=
# REQUIRED for production – must be a Resend-verified domain address.
DEFAULT_FROM_EMAIL=No Reply <no-reply@yourdomain.com>

# ── JWT ──────────────────────────────────────────────────
JWT_ACCESS_HOURS=1
JWT_REFRESH_DAYS=7

# ── Redis / Celery ───────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# ── Gunicorn (production) ────────────────────────────────
PORT=8000
GUNICORN_WORKERS=4
GUNICORN_TIMEOUT=120

# Public URL used in links and callbacks.
# Hosted dev example: https://dev.with-thanks.co.uk
# Production example: https://portal.with-thanks.co.uk
# Production: REQUIRED and must be https.
SERVER_BASE_URL=http://127.0.0.1:8000
